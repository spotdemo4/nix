{
  "buffer_font_family": "Fira Code",
  "cli_default_open_behavior": "new_window",
  "auto_install_extensions": {
    "bash": true,
    "catppuccin-icons": true,
    "git-firefly": true,
    "gleam": true,
    "html": true,
    "ini": true,
    "kotlin": true,
    "log": true,
    "lua": true,
    "neocmake": true,
    "nix": true,
    "oxc": true,
    "proto": true,
    "ruff": true,
    "scss": true,
    "sql": true,
    "svelte": true,
    "tombi": true,
    "toml": true,
    "tsgo": true,
    "zig": true
  },
  "theme": {
    "dark": "Catppuccin Mocha (sky) - No Italics",
    "light": "Catppuccin Mocha (sky) - No Italics"
  },
  "icon_theme": "Catppuccin Mocha",
  "resize_all_panels_in_dock": ["left", "right"],
  "project_panel": {
    "sort_mode": "files_first",
    "dock": "left"
  },
  "git_panel": {
    "dock": "right"
  },
  "ssh_connections": [
    {
      "host": "dev",
      "nickname": "dev",
      "projects": [
        { "paths": ["~/dev/nix"] },
        { "paths": ["~/dev/TrevRPC"] },
        { "paths": ["~/dev/nix-fix-hash"] }
      ]
    }
  ],
  "edit_predictions": {
    "provider": "zed"
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/.direnv"
  ],
  "log": {
    "worktree": "debug",
    "project": "debug"
  },
  "agent": {
    "dock": "right",
    "tool_permissions": {
      "default": "allow"
    },
    "commit_message_model": {
      "provider": "openai",
      "model": "gpt-5.3-codex-spark"
    },
    "commit_message_instructions": "Use the Conventional Commits format: <type>(<scope>): <description>.",
    "favorite_models": [
      {
        "provider": "openrouter",
        "model": "moonshotai/kimi-k3"
      },
      {
        "provider": "openrouter",
        "model": "anthropic/claude-opus-4.7"
      }
    ],
    "profiles": {
      "ask": {
        "name": "Ask",
        "enable_all_context_servers": true
      },
      "minimal": {
        "name": "Minimal",
        "enable_all_context_servers": true
      },
      "write": {
        "name": "Write",
        "enable_all_context_servers": true
      }
    }
  },
  "terminal": {
    "dock": "right",
    "font_family": "DejaVu Sans Mono"
  },
  "outline_panel": {
    "button": false
  },
  "collaboration_panel": {
    "button": false
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
      "default_config_options": {
        "mode": "auto",
        "model": "gpt-5.6-sol",
        "reasoning_effort": "high"
      }
    },
    "opencode": {
      "type": "registry",
      "default_config_options": {
        "mode": "build",
        "effort": "high",
        "model": "openai/gpt-5.6-sol"
      },
      "favorite_config_option_values": {
        "model": ["openai/gpt-5.6-sol", "openai/gpt-5.5-fast"]
      }
    }
  },
  "context_servers": {
    "chrome-devtools": {
      "command": "/home/trev/.local/bin/chrome-devtools-mcp-wrapper",
      "args": []
    },
    "context7": {
      "command": "/home/trev/.local/bin/context7-mcp-wrapper",
      "args": []
    },
    "github": {
      "command": "/home/trev/.local/bin/github-mcp-wrapper",
      "args": ["stdio"]
    },
    "kagi": {
      "command": "/home/trev/.local/bin/kagi-mcp-wrapper",
      "args": []
    },
    "forgejo": {
      "command": "/home/trev/.local/bin/forgejo-mcp-wrapper",
      "args": ["--transport=stdio"]
    }
  }
}
