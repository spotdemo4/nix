{
  "buffer_font_family": "Fira Code",
  "cli_default_open_behavior": "new_window",
  "auto_install_extensions": {
    "bash": true,
    "catppuccin-icons": true,
    "git-firefly": true,
    "gleam": true,
    "html": true,
    "lua": true,
    "neocmake": true,
    "nix": true,
    "oxc": true,
    "proto": true,
    "ruff": true,
    "scss": true,
    "sql": true,
    "svelte": true,
    "tombi": true,
    "toml": true,
    "tsgo": true,
    "zig": true
  },
  "theme": {
    "dark": "Catppuccin Mocha (sky) - No Italics",
    "light": "Catppuccin Mocha (sky) - No Italics"
  },
  "icon_theme": "Catppuccin Mocha",
  "project_panel": {
    "sort_mode": "files_first",
    "dock": "left"
  },
  "ssh_connections": [
    {
      "host": "dev",
      "nickname": "dev",
      "projects": [{ "paths": ["~/dev"] }]
    }
  ],
  "edit_predictions": {
    "provider": "zed"
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/.direnv"
  ],
  "log": {
    "worktree": "debug",
    "project": "debug"
  },
  "agent": {
    "dock": "bottom",
    "tool_permissions": {
      "default": "allow"
    },
    "favorite_models": [
      {
        "provider": "openrouter",
        "model": "moonshotai/kimi-k2.6"
      },
      {
        "provider": "openrouter",
        "model": "anthropic/claude-opus-4.7"
      }
    ],
    "profiles": {
      "ask": {
        "name": "Ask",
        "enable_all_context_servers": true
      },
      "minimal": {
        "name": "Minimal",
        "enable_all_context_servers": true
      },
      "write": {
        "name": "Write",
        "enable_all_context_servers": true
      }
    }
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
      "default_config_options": {
        "mode": "auto",
        "model": "gpt-5.5",
        "reasoning_effort": "xhigh"
      }
    },
    "opencode": {
      "type": "registry",
      "default_config_options": {
        "mode": "build",
        "effort": "xhigh",
        "model": "openai/gpt-5.6-sol-fast"
      },
      "favorite_config_option_values": {
        "model": ["openai/gpt-5.6-sol-fast", "openai/gpt-5.5-fast"]
      }
    }
  },
  "context_servers": {
    "chrome-devtools": {
      "command": "/home/trev/.local/bin/chrome-devtools-mcp-wrapper",
      "args": []
    },
    "context7": {
      "command": "/home/trev/.local/bin/context7-mcp-wrapper",
      "args": []
    },
    "github": {
      "command": "/home/trev/.local/bin/github-mcp-wrapper",
      "args": ["stdio"]
    },
    "kagi": {
      "command": "/home/trev/.local/bin/kagi-mcp-wrapper",
      "args": []
    },
    "forgejo": {
      "command": "/home/trev/.local/bin/forgejo-mcp-wrapper",
      "args": ["--transport=stdio"]
    }
  }
}
