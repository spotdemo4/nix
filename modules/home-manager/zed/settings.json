{
  "$schema": "zed://schemas/settings",
  "buffer_font_family": "Fira Code",
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "sort_mode": "files_first",
    "dock": "left"
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [
      {
        "provider": "openrouter",
        "model": "moonshotai/kimi-k2.6"
      },
      {
        "provider": "openrouter",
        "model": "anthropic/claude-opus-4.7"
      }
    ]
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    }
  }
}
