{
  "buffer_font_family": "Fira Code",
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "sort_mode": "files_first",
    "dock": "left"
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",
    "**/node_modules",
    "**/.direnv"
  ],
  "log": {
    "worktree": "debug",
    "project": "debug"
  },
  "agent": {
    "dock": "bottom",
    "tool_permissions": {
      "default": "allow"
    },
    "favorite_models": [
      {
        "provider": "openrouter",
        "model": "moonshotai/kimi-k2.6"
      },
      {
        "provider": "openrouter",
        "model": "anthropic/claude-opus-4.7"
      }
    ],
    "profiles": {
      "ask": {
        "name": "Ask",
        "enable_all_context_servers": true
      },
      "minimal": {
        "name": "Minimal",
        "enable_all_context_servers": true
      },
      "write": {
        "name": "Write",
        "enable_all_context_servers": true
      }
    }
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry",
      "default_config_options": {
        "mode": "auto",
        "model": "gpt-5.5",
        "reasoning_effort": "xhigh"
      }
    },
    "opencode": {
      "type": "registry",
      "default_config_options": {
        "mode": "build",
        "effort": "xhigh",
        "model": "openai/gpt-5.5"
      },
      "favorite_config_option_values": {
        "model": ["openai/gpt-5.5", "openai/gpt-5.5-pro", "openai/gpt-5.3-codex-spark"]
      }
    }
  }
}
