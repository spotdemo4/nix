{
  "$schema": "https://docs.renovatebot.com/renovate-global-schema.json",

  // self-hosted
  "onboarding": false,
  "requireConfig": "ignored",
  "platform": "github",
  "repositories": ["spotdemo4/nix"],

  // repository
  "extends": ["config:recommended"],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true,
    "schedule": ["* * * * 0"] // sunday
  },
  "nix": {
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "docker images",
      "managerFilePatterns": ["/.*.nix$/"],
      "matchStrings": [
        "image = mkImageOption \"(?<depName>[^\\s:@\"]+)(?::(?<currentValue>[-a-zA-Z0-9.]+))?(?:@(?<currentDigest>sha256:[a-zA-Z0-9]+))?\""
      ],
      "autoReplaceStringTemplate": "image = mkImageOption \"{{{depName}}}{{#if newValue}}:{{{newValue}}}{{else}}{{#if currentValue}}:{{{currentValue}}}{{/if}}{{/if}}{{#if newDigest}}@{{{newDigest}}}{{/if}}\"",
      "depTypeTemplate": "image",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Forgejo runner label docker images",
      "managerFilePatterns": ["/.*.nix$/"],
      "matchStrings": [
        "\"(?<depName>[^\"\\s:]+):docker://(?<packageName>[^\\s:@\"]+):(?<currentValue>[^@\\s\"]+)(?:@(?<currentDigest>sha256:[a-fA-F0-9]+))?\""
      ],
      "autoReplaceStringTemplate": "\"{{{depName}}}:docker://{{{packageName}}}:{{#if newValue}}{{{newValue}}}{{else}}{{{currentValue}}}{{/if}}{{#if newDigest}}@{{{newDigest}}}{{/if}}\"",
      "depTypeTemplate": "image",
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDepTypes": ["image"],
      "groupName": "docker images",
      "pinDigests": true
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "matchFileNames": ["modules/home-manager/opencode/package.json"],
      "groupName": "opencode dependencies"
    },
    {
      "matchPackageNames": ["docker.io/stalwartlabs/stalwart"],
      "enabled": false
    }
  ]
}
